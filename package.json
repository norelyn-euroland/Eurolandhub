{
  "name": "eurolandhub---pro-investor-onboarding",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev:api": "tsx server.js",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev": "npm run dev:all",
    "dev:web:3002": "vite --port 3002",
    "dev:3002": "concurrently \"npm run dev:api\" \"npm run dev:web:3002\"",
    "check:api": "node -e \"fetch('http://localhost:3001/health').then(r=>r.text()).then(t=>console.log(t)).catch(e=>{console.error(e);process.exit(1);})\"",
    "build": "vite build",
    "preview": "vite preview",
    "preview:prod": "npm run build && npm run preview",
    "start": "npm run build && npm run preview"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "apexcharts": "^5.3.6",
    "busboy": "^1.6.0",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "firebase": "^12.8.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lightweight-charts": "^4.1.3",
    "react": "^19.2.3",
    "react-apexcharts": "^1.9.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.3",
    "recharts": "^3.7.0",
    "resend": "^4.8.0",
    "unpdf": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vercel/node": "^5.5.28",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
